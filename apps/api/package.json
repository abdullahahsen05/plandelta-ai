{
  "name": "@plandelta/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint src test prisma.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --passWithNoTests",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:verify-behavior": "tsx prisma/verify-database-behavior.ts",
    "db:verify-clean": "tsx prisma/verify-clean-migration.ts",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "@plandelta/contracts": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.2.3",
    "file-type": "^22.0.1",
    "jose": "^6.2.3",
    "multer": "^2.2.0",
    "pdf-lib": "1.17.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "0.34.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "prisma": "7.8.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
