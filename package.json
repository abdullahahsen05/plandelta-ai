{
  "name": "plandelta-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Evidence-based construction blueprint revision analysis.",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "pnpm db:generate && turbo run build",
    "lint": "pnpm db:generate && turbo run lint",
    "typecheck": "pnpm db:generate && turbo run typecheck",
    "test": "pnpm db:generate && turbo run test",
    "test:e2e": "pnpm db:generate && turbo run test:e2e",
    "verify:local-journey": "node scripts/verify-local-journey.mjs",
    "verify:local-stack": "pnpm --filter @plandelta/api build && node scripts/run-local-integration.mjs",
    "verify:local-e2e": "pnpm --filter @plandelta/api build && node scripts/run-local-integration.mjs --playwright",
    "start:local": "node scripts/run-local-integration.mjs --serve",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @plandelta/api db:generate",
    "db:migrate": "pnpm --filter @plandelta/api db:migrate",
    "db:verify-behavior": "pnpm --filter @plandelta/api db:verify-behavior",
    "db:verify-clean": "pnpm --filter @plandelta/api db:verify-clean",
    "db:seed": "pnpm --filter @plandelta/api db:seed",
    "vision:install": "node scripts/python.mjs -m pip install -e ./apps/vision[dev]",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@supabase/supabase-js": "2.110.7",
    "@types/node": "^24.10.1",
    "dotenv": "17.2.3",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "2.10.5",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "4.1.10"
  }
}
