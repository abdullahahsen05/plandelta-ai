{
	admin off
	auto_https off
	servers {
		protocols h1 h2
	}
}

http://{$PUBLIC_HOST} {
	redir https://{$PUBLIC_HOST}{uri} permanent
}

:443 {
	tls /certs/live/{$PUBLIC_HOST}/fullchain.pem /certs/live/{$PUBLIC_HOST}/privkey.pem

	@invalid_host not header Host {$PUBLIC_HOST}
	respond @invalid_host 421

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		-Server
	}

	reverse_proxy api:4000 {
		health_uri /health/live
		health_interval 15s
		health_timeout 5s
	}
}
