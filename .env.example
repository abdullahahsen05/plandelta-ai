# Shared
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=info

# Web — public values only
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_LIVE_PROCESSING_ENABLED=true
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me

# Supabase / PostgreSQL — server only
SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
DIRECT_DATABASE_URL=postgresql://user:password@host:5432/postgres

# NestJS API and worker
API_PORT=4000
WEB_ORIGINS=http://localhost:3000
JWT_ISSUER=https://example.supabase.co/auth/v1
JWT_AUDIENCE=authenticated
INTERNAL_SERVICE_SECRET=replace_with_a_long_random_value
VISION_SERVICE_URL=http://vision:8000
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=/data
S3_REGION=us-east-1
S3_SIGNED_URL_TTL_SECONDS=300
S3_MAX_READ_BYTES=52428800
MAX_UPLOAD_BYTES=20971520
MAX_PDF_PAGES=50
WORKER_ID=local-worker-1
WORKER_CONCURRENCY=1
JOB_LEASE_SECONDS=300
JOB_MAX_ATTEMPTS=3
VISION_TIMEOUT_SECONDS=240
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_READ_PER_MINUTE=300
RATE_LIMIT_WRITE_PER_MINUTE=60
MAX_UPLOADS_PER_DAY=40
MAX_UPLOAD_BYTES_PER_DAY=524288000
MAX_ANALYSES_PER_HOUR=12
MAX_ACTIVE_ANALYSES=3

# Agent and project knowledge
AGENT_SERVICE_URL=http://agent:8100
AGENT_INTERNAL_TOKEN=replace_with_a_separate_long_random_value
AGENT_CHAT_PROVIDER=bedrock
AGENT_EMBEDDING_PROVIDER=local
AGENT_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
AGENT_EMBEDDING_DIMENSION=384
AGENT_MAX_MODEL_TURNS=8
AGENT_MAX_TOOL_CALLS=12
AGENT_MAX_RETRIEVED_CHUNKS=12
AGENT_MAX_REPAIR_PASSES=1
AGENT_RUN_TIMEOUT_SECONDS=60
AGENT_MAX_ESTIMATED_COST_USD=0.02
AGENT_DAILY_USER_LIMIT=20
AGENT_DAILY_USER_COST_LIMIT_USD=0.20
AGENT_WORKER_CONCURRENCY=1
AGENT_TRACE_CONTENT_ENABLED=false
KNOWLEDGE_MAX_FILE_BYTES=20971520
KNOWLEDGE_MAX_PAGES=100
KNOWLEDGE_CHUNK_SIZE=1200
KNOWLEDGE_CHUNK_OVERLAP=180
KNOWLEDGE_HYBRID_TEXT_WEIGHT=0.45
KNOWLEDGE_HYBRID_VECTOR_WEIGHT=0.55

# Vision
VISION_PORT=8000
VISION_SHARED_ROOT=/data
VISION_SCHEMA_VERSION=1.0
VISION_ENGINE_VERSION=dev
OCR_ENABLED=true
OCR_LANGUAGE=en
# Comparison OCR is enrichment; dense sheets stay deterministic and fail-soft.
VISION_MAX_OCR_REGIONS=4
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=true
ONNX_CLASSIFIER_ENABLED=true
ONNX_MODEL_PATH=apps/vision/models/changed-region-classifier.onnx
ONNX_CONFIDENCE_THRESHOLD=0.78
MAX_IMAGE_PIXELS=60000000
TEMP_DIRECTORY=/tmp/plandelta

# Summary
SUMMARY_PROVIDER=deterministic
BEDROCK_MODEL_ID=replace_when_aws_phase_begins
BEDROCK_REGION=us-east-1
BEDROCK_MAX_OUTPUT_TOKENS=600
BEDROCK_MAX_INPUT_CHARACTERS=12000
BEDROCK_TIMEOUT_MS=30000
BEDROCK_MAX_ATTEMPTS=2

# AWS — prefer an EC2 IAM role; leave access keys unset in production
AWS_PROFILE=plandelta
AWS_REGION=us-east-1
S3_BUCKET=replace_when_aws_phase_begins
S3_PREFIX=plandelta
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
