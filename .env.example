# Shared
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=info

# Web — public values only
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me

# Supabase / PostgreSQL — server only
SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
DIRECT_DATABASE_URL=postgresql://user:password@host:5432/postgres

# NestJS API and worker
API_PORT=4000
WEB_ORIGINS=http://localhost:3000
JWT_ISSUER=https://example.supabase.co/auth/v1
JWT_AUDIENCE=authenticated
INTERNAL_SERVICE_SECRET=replace_with_a_long_random_value
VISION_SERVICE_URL=http://vision:8000
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=/data
MAX_UPLOAD_BYTES=20971520
MAX_PDF_PAGES=50
WORKER_ID=local-worker-1
WORKER_CONCURRENCY=1
JOB_LEASE_SECONDS=300
JOB_MAX_ATTEMPTS=3
VISION_TIMEOUT_SECONDS=240

# Vision
VISION_PORT=8000
VISION_SHARED_ROOT=/data
VISION_SCHEMA_VERSION=1.0
VISION_ENGINE_VERSION=dev
OCR_ENABLED=true
OCR_LANGUAGE=en
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=true
ONNX_CLASSIFIER_ENABLED=true
ONNX_MODEL_PATH=apps/vision/models/changed-region-classifier.onnx
ONNX_CONFIDENCE_THRESHOLD=0.78
MAX_IMAGE_PIXELS=60000000
TEMP_DIRECTORY=/tmp/plandelta

# Summary
SUMMARY_PROVIDER=deterministic
BEDROCK_MODEL_ID=replace_when_aws_phase_begins
BEDROCK_REGION=us-east-1
BEDROCK_MAX_OUTPUT_TOKENS=1200

# AWS — prefer an EC2 IAM role; leave access keys unset in production
AWS_PROFILE=plandelta
AWS_REGION=us-east-1
S3_BUCKET=replace_when_aws_phase_begins
S3_PREFIX=plandelta
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
